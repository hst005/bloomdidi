DATABASE_URL="postgresql://bloomdidi:bloomdidi_dev_password@localhost:5432/bloomdidi?schema=public"
REDIS_URL="redis://localhost:6379"

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Better Auth — https://www.better-auth.com
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
# From Better Auth Infrastructure dashboard → Create project
BETTER_AUTH_API_KEY=

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Razorpay (use test keys in dev)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMS provider (MSG91) — leave empty for dev OTP 123456
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Default delivery fee in paise (5000 = ₹50)
DEFAULT_DELIVERY_FEE_PAISE=5000
